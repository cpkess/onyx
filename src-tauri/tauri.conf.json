{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Onyx",
  "version": "0.1.3",
  "identifier": "com.onyx.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Onyx",
        "width": 1280,
        "height": 800,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/cpkess/onyx/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEY4N0EwMkU2REU4MzQ0MTAKUldRUVJJUGU1Z0o2K0RrUkYvMXFXYUx6UHh5LzRkUlRqNUUzSmpPZE5TbzYrMTEvNkxRdTFzOG4K"
    }
  }
}
